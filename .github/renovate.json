{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":semanticCommitType(chore)",
        "helpers:githubDigestChangelogs",
        "mergeConfidence:age-confidence-badges"
    ],
    "dependencyDashboard": true,
    "dependencyDashboardApproval": false,
    "rangeStrategy": "bump",
    "packageRules": [
        {
            "groupName": "patch dependencies",
            "groupSlug": "all-patch",
            "description": "Auto-merge safe patch updates",
            "matchUpdateTypes": [
                "patch"
            ],
            "automerge": true
        },
        {
            "groupName": "minor dependencies",
            "groupSlug": "all-minor",
            "description": "Group minor updates (manual review)",
            "matchUpdateTypes": [
                "minor"
            ],
            "automerge": false
        },
        {
            "groupName": "major dependencies",
            "groupSlug": "all-major",
            "description": "Group major updates (manual review)",
            "matchUpdateTypes": [
                "major"
            ],
            "automerge": false
        },
        {
            "matchPackageNames": [
                "@types/node",
                "@tsconfig/node22"
            ],
            "enabled": false
        }
    ],
    "schedule": [
        "before 7am on monday"
    ],
    "automergeType": "pr",
    "minimumReleaseAge": "7 days"
}