{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "dependencyDashboard": true,
    "rangeStrategy": "bump",
    "packageRules": [
        {
            "description": "Auto-merge safe patch updates",
            "matchUpdateTypes": [
                "patch"
            ],
            "groupName": "patch dependencies",
            "automerge": true
        },
        {
            "description": "Group minor updates (manual review)",
            "matchUpdateTypes": [
                "minor"
            ],
            "groupName": "minor dependencies",
            "automerge": false
        },
        {
            "description": "Disable major updates",
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        },
        {
            "description": "Disable replacement updates",
            "matchUpdateTypes": [
                "replacement"
            ],
            "enabled": false
        },
        {
            "description": "Allow specific replacement updates",
            "matchPackageNames": [
                "eslint",
                "vite",
                "vue",
                "discord.js",
                "@discordjs/*"
            ],
            "matchUpdateTypes": [
                "replacement"
            ],
            "enabled": true
        }
    ],
    "schedule": [
        "before 6am on monday"
    ],
    "prCreation": "not-pending"
}