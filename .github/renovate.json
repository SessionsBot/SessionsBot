{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "dependencyDashboard": false,
    "rangeStrategy": "bump",
    "packageRules": [
        {
            "description": "ONLY allow minor + patch updates",
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "groupName": "dependencies",
            "groupSlug": "dependencies"
        },
        {
            "description": "Completely ignore major updates",
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        }
    ],
    "schedule": [
        "before 6am on monday"
    ]
}