{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":semanticCommitType(chore)",
        "helpers:githubDigestChangelogs",
        "mergeConfidence:age-confidence-badges"
    ],
    "dependencyDashboard": true,
    "dependencyDashboardApproval": false,
    "automergeType": "pr",
    "rangeStrategy": "bump",
    "packageRules": [
        {
            "groupName": null,
            "groupSlug": null,
            "description": "Auto-merge patch updates",
            "matchUpdateTypes": [
                "patch"
            ],
            "minimumReleaseAge": "1 day",
            "automerge": true
        },
        {
            "groupName": "minor dependencies",
            "groupSlug": "all-minor",
            "description": "Group minor updates (manual review)",
            "matchUpdateTypes": [
                "minor"
            ],
            "minimumReleaseAge": "3 days",
            "automerge": false
        },
        {
            "groupName": "major dependencies",
            "groupSlug": "all-major",
            "description": "Group major updates (manual review)",
            "matchUpdateTypes": [
                "major"
            ],
            "minimumReleaseAge": "7 days",
            "automerge": false
        },
        {
            "groupName": "node engine",
            "matchDepNames": [
                "node"
            ],
            "matchDepTypes": [
                "engines"
            ],
            "enabled": false
        },
        {
            "groupName": "node dependencies",
            "matchPackageNames": [
                "@types/node",
                "@tsconfig/node22"
            ],
            "enabled": false
        }
    ]
}