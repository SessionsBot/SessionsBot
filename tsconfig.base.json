{
    
    "compilerOptions": {
        "baseUrl": ".",
        "module": "esnext",
        "target": "ES2022",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "moduleResolution": "bundler",
        "sourceMap": true,

        "paths": {
            "@sessionsbot/shared": ["packages/shared/src"],
            "@sessionsbot/shared/*": ["packages/shared/src/*"]
        }
    },
}