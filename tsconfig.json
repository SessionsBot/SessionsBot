{
    "compilerOptions": {
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "noEmit": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "moduleResolution": "node"
    },
    "references": [
        { "path": "./packages/shared" },
        { "path": "./apps/backend" },
        { "path": "./apps/frontend" },
        { "path": "./apps/docs" }
    ],
    "exclude": [
        "*README.md"
    ]
}