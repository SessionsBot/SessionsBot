{
  // "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": ".vitepress/dist",

    "paths": {
      "@components/*": ["./src/components/*"],
      "@theme/*": ["./.vitepress/theme/*"]
    }
  },
  "include": [
    "src",
    ".vitepress",
    "**/*.md"
  ],
  "references": [
    { "path": "../../packages/shared" }
  ],
  "vueCompilerOptions": {
    "vitePressExtensions": [".md"]
  }
}
